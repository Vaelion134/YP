<Page x:Class="доставка.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:доставка"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePage" Background="#121212">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">

            <Button Content="Все" Click="All_Click"/>
            <Button Content="Пицца" Click="Pizza_Click"/>
            <Button Content="Бургеры" Click="Burger_Click"/>
            <Button Content="Суши" Click="Sushi_Click"/>

        </StackPanel>

        <ScrollViewer Grid.Row="1">

            <ItemsControl x:Name="MenuItemsControl">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Width="220"
                                Margin="10"
                                Background="#1E1E1E"
                                CornerRadius="10">

                            <StackPanel Margin="10">
                                
                                <Image Height="120"
                                           Stretch="Fill"
                                           Source="{Binding ImagePath}" />

                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding Category}"
                                           Foreground="Gray"
                                           Margin="0,5"/>

                                <TextBlock Text="{Binding Price,
                                                  StringFormat={}{0} руб}"
                                           Foreground="#00C896"
                                           FontSize="16"/>

                                <Button Content="В корзину"
                                        Margin="0,10,0,0"
                                        Click="AddToCart"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

    </Grid>


</Page>
