<Page x:Class="доставка.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:доставка"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePage" Background="#121212">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="10">

            <Button Content="Все" Click="All_Click"/>
            <Button Content="Пицца" Click="Pizza_Click"/>
            <Button Content="Бургеры" Click="Burger_Click"/>
            <Button Content="Суши" Click="Sushi_Click"/>

        </StackPanel>

        <ScrollViewer Grid.Row="1">

            <WrapPanel x:Name="ItemsPanel" Margin="10">

                <Border Tag="Pizza"
                        Width="200"
                        Background="#1E1E1E"
                        CornerRadius="10"
                        Margin="10">

                    <StackPanel>

                        <Image Height="120"/>

                        <TextBlock Text="Pizza City"
                                   Foreground="White"
                                   Margin="10,5,10,0"/>

                        <TextBlock Text="8.50 €"
                                   Foreground="#00C896"
                                   Margin="10,0,10,5"/>

                        <Button Content="В корзину"
                                Tag="Pizza"
                                Click="AddToCart"/>

                    </StackPanel>

                </Border>

                <Border Tag="Burger"
                        Width="200"
                        Background="#1E1E1E"
                        CornerRadius="10"
                        Margin="10">

                    <StackPanel>

                        <Image Height="120"/>

                        <TextBlock Text="Burger House"
                                   Foreground="White"
                                   Margin="10,5,10,0"/>

                        <TextBlock Text="6.00 €"
                                   Foreground="#00C896"
                                   Margin="10,0,10,5"/>

                        <Button Content="В корзину"
                                Tag="Burger"
                                Click="AddToCart"/>

                    </StackPanel>

                </Border>

                <Border Tag="Sushi"
                        Width="200"
                        Background="#1E1E1E"
                        CornerRadius="10"
                        Margin="10">

                    <StackPanel>

                        <Image Height="120"/>

                        <TextBlock Text="Sushi Bar"
                                   Foreground="White"
                                   Margin="10,5,10,0"/>

                        <TextBlock Text="10.00 €"
                                   Foreground="#00C896"
                                   Margin="10,0,10,5"/>

                        <Button Content="В корзину"
                                Tag="Sushi"
                                Click="AddToCart"/>

                    </StackPanel>

                </Border>

            </WrapPanel>

        </ScrollViewer>

    </Grid>

</Page>
