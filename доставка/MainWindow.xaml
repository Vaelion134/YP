<Window x:Class="доставка.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:доставка"
        mc:Ignorable="d"
        Title="FoodGo" Height="750" Width="1200"
        Background="#121212">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Background="#1E1E1E">
            <Grid Margin="10">

                <TextBlock Text="FoodGo"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Главная" Width="90"
                            Click="Home_Click"/>

                    <Button Content="Корзина" Width="90"
                            Click="Cart_Click"/>

                    <Button x:Name="AuthButton"
                            Content="Войти"
                            Width="90"
                            Click="Auth_Click"/>

                </StackPanel>

            </Grid>
        </Border>

        <Frame x:Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"/>

        <Border Grid.Row="2" Background="#1E1E1E">
            <TextBlock Text="© FoodGo 2026"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>