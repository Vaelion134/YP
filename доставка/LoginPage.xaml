<Page x:Class="доставка.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:доставка"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage" Background="#121212">

    <Grid>

        <Border Width="350"
                Padding="20"
                Background="#1E1E1E"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Регистрация / Вход"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <TextBox x:Name="UsernameBox"
                         Height="40"
                         Margin="0,5"
                         Background="#2A2A2A"
                         Foreground="White"
                         Padding="8"
                         BorderThickness="0"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="40"
                             Margin="0,5"
                             Background="#2A2A2A"
                             Foreground="White"
                             Padding="8"
                             BorderThickness="0"/>

                <Button Content="Войти"
                        Height="40"
                        Margin="0,10,0,0"
                        Background="#00C896"
                        Foreground="White"
                        Click="Login_Click"/>

                <Button Content="Регистрация"
                        Height="40"
                        Margin="0,10,0,0"
                        Background="#333333"
                        Foreground="White"
                        Click="Register_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Page>