<Window x:Class="доставка.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:доставка"
        mc:Ignorable="d"
        Title="CartWindow" Height="500" Width="400" Background="#121212">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Корзина"
               Foreground="White"
               FontSize="26"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

        <ListBox x:Name="CartList"
             Grid.Row="1"
             Background="#1E1E1E"
             Foreground="White"
             BorderThickness="0"
             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <TextBlock x:Name="TotalText"
               Grid.Row="2"
               Foreground="#00C896"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,10"/>

        <StackPanel Grid.Row="3">

            <Button Content="Очистить"
                Height="40"
                Margin="0,0,0,10"
                Click="Clear_Click"/>

            <Button Content="Заказать"
                Height="45"
                Background="#00C896"
                Foreground="White"
                FontWeight="Bold"
                Click="Order_Click"/>

        </StackPanel>

    </Grid>
</Window>
