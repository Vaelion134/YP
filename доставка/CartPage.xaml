<Page x:Class="доставка.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:доставка"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CartPage"
      Background="#121212">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- СПИСОК -->
        <ListBox x:Name="CartList"
                 Background="#1E1E1E"
                 Foreground="White"
                 Margin="0,0,0,10"/>

        <!-- НИЖНЯЯ ПАНЕЛЬ -->
        <StackPanel Grid.Row="1">

            <TextBlock x:Name="TotalText"
                       Foreground="#00C896"
                       FontSize="20"
                       Margin="0,5"/>

            <TextBox x:Name="AddressBox"
                     Height="35"
                     Margin="0,5"
                     Background="#2A2A2A"
                     Foreground="White"
                     Text="Введите адрес доставки"/>

            <Button Content="Удалить выбранное"
                    Height="35"
                    Margin="0,5"
                    Click="RemoveSelected_Click"/>

            <Button Content="Очистить корзину"
                    Height="35"
                    Margin="0,5"
                    Click="Clear_Click"/>

            <Button Content="Заказать"
                    Height="40"
                    Background="#00C896"
                    Foreground="White"
                    Click="Order_Click"/>

        </StackPanel>

    </Grid>


</Page>